<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette for the flyout and context menu -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FF1B1D22" />
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FF2C2F38" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF2F3F5" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF8A8F98" />
    <SolidColorBrush x:Key="TrackBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="HoverBrush" Color="#FF2E394B" />
    <SolidColorBrush x:Key="DisabledBrush" Color="#FF6E7681" />

</ResourceDictionary>
