<Window x:Class="ClaudeStatus.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="320"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <!-- Outer margin leaves room for the drop shadow. -->
    <Border Margin="12"
            CornerRadius="12"
            Background="#FF1B1D22"
            BorderBrush="#FF2C2F38"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <StackPanel Margin="16,14,16,16">
            <!-- Header -->
            <Grid>
                <TextBlock Text="Claude usage"
                           Foreground="#FFF2F3F5"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="UpdatedText"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="#FF8A8F98"
                           FontSize="11" />
            </Grid>

            <!-- One row per limit window -->
            <ItemsControl x:Name="RowsList" Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,12,0,0">
                            <Grid>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#FFE3E5E8"
                                           FontSize="12.5" />
                                <TextBlock Text="{Binding PercentText}"
                                           HorizontalAlignment="Right"
                                           Foreground="#FFF2F3F5"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                            </Grid>
                            <!-- Progress track -->
                            <Border Height="7"
                                    Width="288"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Background="#22FFFFFF"
                                    Margin="0,6,0,0">
                                <Border HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Width="{Binding FillWidth}"
                                        Background="{Binding FillBrush}" />
                            </Border>
                            <TextBlock Text="{Binding ResetText}"
                                       Foreground="#FF8A8F98"
                                       FontSize="11"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status / error line (hidden when there is data) -->
            <TextBlock x:Name="MessageText"
                       Foreground="#FFB0B4BB"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="Collapsed" />
        </StackPanel>
    </Border>
</Window>
